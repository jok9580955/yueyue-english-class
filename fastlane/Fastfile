default_platform(:ios)

APP_IDENTIFIER = "com.liuqingyue.EnglishSprout"
APP_NAME = "钥钥的英语课"
DEFAULT_ASC_KEY_ID = "JD5G4LG5XN"
DEFAULT_ASC_ISSUER_ID = "f68594d0-23a9-480d-8f1d-6c84b40bf664"
DEFAULT_ASC_KEY_FILE = "/Users/ll/Desktop/AuthKey_JD5G4LG5XN.p8"
FASTLANE_DIR = __dir__
METADATA_PATH = File.join(FASTLANE_DIR, "metadata")
SCREENSHOTS_PATH = File.join(FASTLANE_DIR, "screenshots")

def asc_api_key
  key_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ID", DEFAULT_ASC_KEY_ID)
  issuer_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID", DEFAULT_ASC_ISSUER_ID)
  key_file = ENV.fetch("APP_STORE_CONNECT_API_KEY_KEYFILEPATH", DEFAULT_ASC_KEY_FILE)

  UI.user_error!("Missing App Store Connect key file: #{key_file}") unless File.exist?(key_file)

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_file,
    duration: 1200,
    in_house: false
  )
end

def app_review_information_from_env
  required_keys = %w[
    APP_REVIEW_FIRST_NAME
    APP_REVIEW_LAST_NAME
    APP_REVIEW_PHONE
    APP_REVIEW_EMAIL
  ]
  return nil unless required_keys.all? { |key| ENV[key].to_s.strip.length.positive? }

  {
    first_name: ENV.fetch("APP_REVIEW_FIRST_NAME"),
    last_name: ENV.fetch("APP_REVIEW_LAST_NAME"),
    phone_number: ENV.fetch("APP_REVIEW_PHONE"),
    email_address: ENV.fetch("APP_REVIEW_EMAIL"),
    notes: ENV.fetch("APP_REVIEW_NOTES", "This app does not require login. No demo account is required.")
  }
end

def base_deliver_options
  {
    app_identifier: APP_IDENTIFIER,
    api_key: asc_api_key,
    force: true,
    submit_for_review: false,
    automatic_release: false,
    run_precheck_before_submit: false,
    precheck_include_in_app_purchases: false
  }
end

platform :ios do
  desc "Validate upload prerequisites without uploading"
  lane :status do
    UI.message("App: #{APP_NAME}")
    UI.message("Bundle ID: #{APP_IDENTIFIER}")
    UI.message("Metadata locales: #{Dir.glob(File.join(METADATA_PATH, '*')).select { |p| File.directory?(p) }.map { |p| File.basename(p) }.sort.join(', ')}")
    UI.message("Screenshots directory exists: #{Dir.exist?(SCREENSHOTS_PATH)}")
    UI.message("ASC key exists: #{File.exist?(ENV.fetch('APP_STORE_CONNECT_API_KEY_KEYFILEPATH', DEFAULT_ASC_KEY_FILE))}")
  end

  desc "Upload App Store metadata only"
  lane :upmeta do
    options = base_deliver_options.merge(
      metadata_path: METADATA_PATH,
      skip_metadata: false,
      skip_screenshots: true,
      skip_binary_upload: true
    )
    review_information = app_review_information_from_env
    options[:app_review_information] = review_information if review_information
    deliver(options)
  end

  desc "Upload App Store screenshots only"
  lane :uppic do
    UI.user_error!("Missing fastlane/screenshots. Generate screenshots before uploading.") unless Dir.exist?(SCREENSHOTS_PATH)

    deliver(base_deliver_options.merge(
      screenshots_path: SCREENSHOTS_PATH,
      skip_metadata: true,
      skip_screenshots: false,
      skip_binary_upload: true
    ))
  end
end
